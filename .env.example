# Option A: default credentials
WP_USERNAME=api-bot
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_BACKUP_USERNAME=api-bot
WP_BACKUP_APP_PASSWORD=yyyy yyyy yyyy yyyy yyyy yyyy

# Option B: namespaced by auth_ref in task.site.auth_ref
# If auth_ref is WP_MAIN, set:
WP_MAIN_USERNAME=api-bot
WP_MAIN_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional default site
WP_BASE_URL=https://example.com
WP_API_BASE=https://example.com/wp-json/wp/v2
