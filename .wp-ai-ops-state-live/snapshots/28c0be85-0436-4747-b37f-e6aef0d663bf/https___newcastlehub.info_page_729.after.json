y\":[{\"@type\":\"Question\",\"name\":\"Can you sync online and in-store stock?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We structure product and inventory mapping so your online and POS stock stay aligned.\"}},{\"@type\":\"Question\",\"name\":\"Do you support pickup and shipping workflows?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We configure local pickup, shipping rules, and checkout flow based on your operation.\"}},{\"@type\":\"Question\",\"name\":\"Can this work for small local shops?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We tailor setup for local stores starting ecommerce without overcomplicating operations.\"}}]}</script></div></div></div></div></div></section>",
