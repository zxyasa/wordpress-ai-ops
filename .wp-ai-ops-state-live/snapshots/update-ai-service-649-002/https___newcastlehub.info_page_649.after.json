-bottom: 10px;\n        }\n        .pricing-tier .price {\n            font-size: 1.5em;\n            font-weight: bold;\n            margin-bottom: 20px;\n        }\n        .pricing-tier .cta {\n            display: inline-block;\n            padding: 10px 20px;\n            color: white;\n            background-color: #007bff;\n            text-decoration: none;\n            border-radius: 5px;\n        }\n        .pricing-tier .cta:hover {\n            background-color: #0056b3;\n        }\n    </style>\n</head>\n<body>\n    <header>\n\n    </header>\n\n    <main>\n        <section class=\"hero\">\n            <h1>Create your AI Avatar</h1>\n            <p>Built for Newcastle service businesses: deploy practical AI to answer enquiries faster, qualify leads, and reduce manual admin.</p>\n        </section>\n\n        <section class=\"pricing\">\n            <div class=\"pricing-tier\">\n                <h2>Foundation</h2>\n                <p class=\"price\">AI Lead Capture Setup</p>\n                <p>For new local businesses</p>\n                <ul>\n                    <li>Website AI assistant setup</li>\n                    <li>Service-aware FAQ and response flow</li>\n                    <li>Lead capture form optimisation</li>\n                </ul>\n                <a href=\"https://newcastlehub.info/contact/\" class=\"cta\">Book a Strategy Call</a>\n            </div>\n            <div class=\"pricing-tier\">\n                <h2>Growth</h2>\n                <p class=\"price\">AI Workflow + Triage</p>\n                <p>For teams ready to scale</p>\n                <ul>\n                    <li>Lead triage by service type and urgency</li>\n                    <li>Booking or quote pre-qualification flow</li>\n                    <li>Monthly prompt and conversion optimisation</li>\n                </ul>\n                <a href=\"https://newcastlehub.info/free-newcastle-business-audit/\" class=\"cta\">Get Free Business Audit</a>\n            </div>\n            <div class=\"pricing-tier\">\n                <h2>Scale</h2>\n                <p class=\"price\">Integrated AI Operations</p>\n                <p>For established operations</p>\n                <ul>\n                    <li>Multi-page AI conversion flow rollout</li>\n                    <li>CRM and team handoff integration support</li>\n                    <li>Ongoing monitoring and optimisation roadmap</li>\n                </ul>\n                <a href=\"https://newcastlehub.info/contact/\" class=\"cta\">Request Implementation Plan</a>\n            </div>\n        </section>\n    </main>\n\n\n</body>\n</html>\n<!-- /wp:flatsome/uxbuilder -->\n\n<!-- wp:paragraph -->\n<p>Call <a href=\"tel:0240755307\">02 40755307</a> or email <a href=\"mailto:hello@newcastlehub.info\">hello@newcastlehub.info</a> to discuss your AI roadmap.</p>\n<!-- /wp:paragraph -->",
