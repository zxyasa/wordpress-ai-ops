    "raw": "<!-- wp:html -->\n<div id=\"paypal-button-container-P-54C935957F403973YME3V6KI\"></div>\n<script src=\"https://www.paypal.com/sdk/js?client-id=AZu7YCBQ6K1g65JP3Oh-tCdjzNUXvwJrsP0VRZJgSWt3C8pk_9TUu6guT2qHtc2nicBU6aDStX0x_P-2&vault=true&intent=subscription\" data-sdk-integration-source=\"button-factory\"></script>\n<script>\n  paypal.Buttons({\n      style: {\n          shape: 'rect',\n          color: 'gold',\n          layout: 'vertical',\n          label: 'subscribe'\n      },\n      createSubscription: function(data, actions) {\n        return actions.subscription.create({\n          /* Creates the subscription */\n          plan_id: 'P-54C935957F403973YME3V6KI'\n        });\n      },\n      onApprove: function(data, actions) {\n        alert(data.subscriptionID); // You can add optional success message for the subscriber here\n      }\n  }).render('#paypal-button-container-P-54C935957F403973YME3V6KI'); // Renders the PayPal button\n</script>\n<!-- /wp:html -->\n\n<section class=\"section\" id=\"ai-hosting-freedom-seo\" style=\"padding-top:48px;padding-bottom:48px;background-color:#f3f3f3;\"><div class=\"section-content relative\"><div class=\"row\"><div class=\"col small-12 large-12\"><div class=\"col-inner\"><div class=\"text\"><!-- AI_SLOT:INTRO --><h2>Freedom Hosting for Growing Business Websites</h2><p>The Freedom plan balances performance, flexibility, and support for businesses that are scaling traffic, campaigns, and service pages.</p><!-- /AI_SLOT:INTRO --><h3>Best for</h3><ul><li>Established local businesses</li><li>Sites running active SEO and marketing campaigns</li><li>Teams needing stronger performance headroom</li></ul><!-- AI_SLOT:FAQ --><h3>Freedom Plan FAQ</h3><h4>What is the difference from Starter?</h4><p>Freedom gives more resources and better fit for growing traffic and heavier page usage.</p><h4>Can this handle multiple landing pages?</h4><p>Yes. It is designed for businesses running broader content and campaign structures.</p><h4>Do you provide technical help during growth?</h4><p>Yes. We support performance checks and practical adjustments as your site expands.</p><!-- /AI_SLOT:FAQ --><!-- AI_SLOT:CTA --><p><a class=\"button primary is-large\" href=\"https://newcastlehub.info/contact/\">Choose Freedom Hosting</a></p><p>Need higher capacity? See <a href=\"https://newcastlehub.info/web-hosting-premier/\">Premier Plan</a>.</p><!-- /AI_SLOT:CTA --><!-- AI_SLOT:SCHEMA --><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is the difference from Starter?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Freedom gives more resources and better fit for growing traffic and heavier page usage.\"}},{\"@type\":\"Question\",\"name\":\"Can this handle multiple landing pages?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. It is designed for businesses running broader content and campaign structures.\"}},{\"@type\":\"Question\",\"name\":\"Do you provide technical help during growth?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We support performance checks and practical adjustments as your site expands.\"}}]}</script><!-- /AI_SLOT:SCHEMA --></div></div></div></div></div></section>\n",
    "rendered": "\n<div id=\"paypal-button-container-P-54C935957F403973YME3V6KI\"></div>\n<script src=\"https://www.paypal.com/sdk/js?client-id=AZu7YCBQ6K1g65JP3Oh-tCdjzNUXvwJrsP0VRZJgSWt3C8pk_9TUu6guT2qHtc2nicBU6aDStX0x_P-2&#038;vault=true&#038;intent=subscription\" data-sdk-integration-source=\"button-factory\"></script>\n<script>\n  paypal.Buttons({\n      style: {\n          shape: 'rect',\n          color: 'gold',\n          layout: 'vertical',\n          label: 'subscribe'\n      },\n      createSubscription: function(data, actions) {\n        return actions.subscription.create({\n          /* Creates the subscription */\n          plan_id: 'P-54C935957F403973YME3V6KI'\n        });\n      },\n      onApprove: function(data, actions) {\n        alert(data.subscriptionID); // You can add optional success message for the subscriber here\n      }\n  }).render('#paypal-button-container-P-54C935957F403973YME3V6KI'); // Renders the PayPal button\n</script>\n\n\n<section class=\"section\" id=\"ai-hosting-freedom-seo\" style=\"padding-top:48px;padding-bottom:48px;background-color:#f3f3f3;\"><div class=\"section-content relative\"><div class=\"row\"><div class=\"col small-12 large-12\"><div class=\"col-inner\"><div class=\"text\"><!-- AI_SLOT:INTRO --><h2>Freedom Hosting for Growing Business Websites</h2><p>The Freedom plan balances performance, flexibility, and support for businesses that are scaling traffic, campaigns, and service pages.</p><!-- /AI_SLOT:INTRO --><h3>Best for</h3><ul><li>Established local businesses</li><li>Sites running active SEO and marketing campaigns</li><li>Teams needing stronger performance headroom</li></ul><!-- AI_SLOT:FAQ --><h3>Freedom Plan FAQ</h3><h4>What is the difference from Starter?</h4><p>Freedom gives more resources and better fit for growing traffic and heavier page usage.</p><h4>Can this handle multiple landing pages?</h4><p>Yes. It is designed for businesses running broader content and campaign structures.</p><h4>Do you provide technical help during growth?</h4><p>Yes. We support performance checks and practical adjustments as your site expands.</p><!-- /AI_SLOT:FAQ --><!-- AI_SLOT:CTA --><p><a class=\"button primary is-large\" href=\"https://newcastlehub.info/contact/\">Choose Freedom Hosting</a></p><p>Need higher capacity? See <a href=\"https://newcastlehub.info/web-hosting-premier/\">Premier Plan</a>.</p><!-- /AI_SLOT:CTA --><!-- AI_SLOT:SCHEMA --><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is the difference from Starter?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Freedom gives more resources and better fit for growing traffic and heavier page usage.\"}},{\"@type\":\"Question\",\"name\":\"Can this handle multiple landing pages?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. It is designed for businesses running broader content and campaign structures.\"}},{\"@type\":\"Question\",\"name\":\"Do you provide technical help during growth?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We support performance checks and practical adjustments as your site expands.\"}}]}</script><!-- /AI_SLOT:SCHEMA --></div></div></div></div></div></section>\n",
